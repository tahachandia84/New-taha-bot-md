# ====================================
# SHEHBAZ-MD v1.0.0 - Environment Configuration
# ====================================
# Created by: Shehbaz—Dev
# Date: 2026
# ====================================

# ========== 🔐 SESSION & AUTH ==========
# Get this after pairing from /pair endpoint
SESSION_ID=

# ========== 🤖 BOT BASIC SETTINGS ==========
# Command prefix (., !, /, #, etc.)
PREFIX=.

# Bot display name
BOT_NAME=SHEHBAZ-MD

# Bot mode: public (everyone can use) or private (only owner)
MODE=public

# Default sticker pack name
STICKER_NAME=SHEHBAZ-MD

# ========== 👑 OWNER CONFIGURATION ==========
# Multiple owners supported (comma separated)
# Format: countrycode + number (without + or 00)
OWNER_NUMBER=923212844383
# OWNER_NUMBER=923212844383,923392616263,923451234567

# Owner display name
OWNER_NAME=Shehbaz

# Developer number (alias for primary owner)
DEV=923212844383

# ========== 🛡️ SECURITY & ANTI FEATURES ==========
# Block/reject incoming calls
ANTI_CALL=true

# Detect and log deleted messages
ANTI_DELETE=true

# Where to send anti-delete logs: 'same' (to group) or 'owner'
ANTI_DELETE_TYPE=same

# Delete links from groups
ANTI_LINK=true

# Detect and warn other bots
ANTI_BOT=true

# Block bad words/banned content
ANTI_BAD=true

# Anti-viewonce (save viewonce media)
ANTI_VV=true

# Auto-block spam numbers
AUTO_BLOCK=false

# Delete links from groups (old name - kept for compatibility)
DELETE_LINKS=false

# ========== 👥 GROUP FEATURES ==========
# Send welcome message when member joins
SEND_WELCOME=false

# Send goodbye message when member leaves
GOODBYE=false

# Log admin events in groups (promote, demote, etc.)
ADMIN_EVENTS=false

# ========== 📱 STATUS FEATURES ==========
# Auto-see status updates
AUTO_STATUS_SEEN=true

# Auto-reply to status updates
AUTO_STATUS_REPLY=false

# Auto-react to status updates
AUTO_STATUS_REACT=false

# Custom auto-reply message for status
AUTO_STATUS_MSG="*SEEN YOUR STATUS BY SHEHBAZ-MD 🤍*"

# Auto-update bot bio/description
AUTO_BIO=true

# ========== 💬 MESSAGE HANDLING ==========
# Auto-read incoming messages
READ_MESSAGE=true

# Read only command messages (not regular chats)
READ_CMD_ONLY=true

# Auto-reply to unknown commands
AUTO_REPLY=true

# Read command messages specifically
READ_CMD=false

# ========== 🎭 PRESENCE & ONLINE STATUS ==========
# Always show online status
ALWAYS_ONLINE=true

# Show typing indicator when processing
AUTO_TYPING=true

# Show recording indicator
AUTO_RECORDING=true

# ========== 🎨 REACTION FEATURES ==========
# Auto-react to messages
AUTO_REACT=true

# Enable custom reactions (uses CUSTOM_REACT_EMOJIS)
CUSTOM_REACT=false

# List of emojis for custom reactions (comma separated)
CUSTOM_REACT_EMOJIS=💝,💖,💗,❤️‍🩹,❤️,🧡,💛,💚,💙,💜,🤎,🖤,🤍

# ========== 🎵 MEDIA FEATURES ==========
# Auto-convert voice notes to text
AUTO_VOICE=true

# Auto-convert images to stickers
AUTO_STICKER=false

# ========== 🌐 API CONFIGURATION ==========
# External API base URL
API_BASE=https://shehbaz-api.vercel.app/

# API authentication key
API_KEY=shehbazmdadmin

# ========== ⚙️ ADVANCED ==========
# Node environment (production/development)
NODE_ENV=production

# Server port (default: 8000)
PORT=8000

# API secret for web routes
API_SECRET=shehbazmd2024

# ====================================
# ⚡ DON'T FORGET TO UPDATE OWNER_NUMBER
# ====================================